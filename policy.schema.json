{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
  "title": "Rexo policy configuration schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "name",
    "commands",
    "aliases"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
        "https://raw.githubusercontent.com/agile-north/rexo/release/next/policy.schema.json",
        "https://raw.githubusercontent.com/agile-north/rexo/schema/v1.0/policy.schema.json",
        "policy.schema.json",
        "./policy.schema.json",
        "../policy.schema.json",
        ".rexo/policy.schema.json"
      ]
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "commands": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/repoCommand"
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "repoCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/argConfig"
          }
        },
        "options": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/optionConfig"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          }
        }
      }
    },
    "argConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "optionConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "default": {
          "type": "string"
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "uses": {
          "type": "string"
        },
        "run": {
          "type": "string"
        },
        "when": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "anyOf": [
        { "required": ["run"] },
        { "required": ["uses"] },
        { "required": ["command"] }
      ]
    }
  }
}

{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
  "schemaVersion": "1.0",
  "name": "dotnet-policy",
  "description": ".NET toolchain command contributions. Usable standalone or overlaid with embedded:standard.",
  "commands": {
    "restore": {
      "description": "Restore .NET dependencies.",
      "steps": [
        {
          "id": "dotnet-restore",
          "run": "dotnet restore {{settings.dotnet.solution | default('')}}"
        }
      ]
    },
    "build": {
      "description": "Build .NET projects.",
      "steps": [
        {
          "id": "dotnet-build",
          "run": "dotnet build {{settings.dotnet.solution | default('')}} -c {{settings.dotnet.configuration | default('Release')}} --no-restore"
        }
      ]
    },
    "test": {
      "description": "Run .NET tests.",
      "steps": [
        {
          "id": "dotnet-test",
          "run": "dotnet test {{settings.dotnet.solution | default('')}} -c {{settings.dotnet.configuration | default('Release')}} --logger {{settings.dotnet.test.logger | default('trx')}} {{outputs.tests.results | prefix('--results-directory ')}} {{settings.dotnet.test.coverageArgs | default('')}} {{settings.dotnet.test.args | default('')}}",
          "outputs": {
            "testResults": [
              "{{outputs.tests.results}}/**/*.trx",
              "{{outputs.tests.results}}/**/*.xml"
            ],
            "coverage": [
              "{{outputs.tests.coverage}}/**/*.xml",
              "{{outputs.tests.coverage}}/**/*.cobertura.xml"
            ]
          }
        }
      ]
    },
    "analyze": {
      "description": "Run .NET code analysis.",
      "steps": [
        {
          "id": "dotnet-format-check",
          "run": "dotnet format {{settings.dotnet.solution | default('')}} --verify-no-changes {{outputs.analysis.reports | prefix('--report ')}} {{settings.dotnet.analyze.formatArgs | default('')}}",
          "outputs": {
            "analysisReports": [
              "{{outputs.analysis.reports}}/**/*.json"
            ]
          }
        },
        {
          "id": "dotnet-build-warnings",
          "run": "dotnet build {{settings.dotnet.solution | default('')}} -c {{settings.dotnet.configuration | default('Release')}} -warnaserror --no-restore {{outputs.analysis.sarif | prefix('/p:ErrorLog=')}} {{settings.dotnet.analyze.errorLogArgs | default('')}} {{settings.dotnet.analyze.buildArgs | default('')}}",
          "outputs": {
            "sarifReports": [
              "{{outputs.analysis.sarif}}"
            ]
          }
        }
      ]
    },
    "format": {
      "description": "Auto-format .NET source files.",
      "steps": [
        {
          "id": "dotnet-format",
          "run": "dotnet format {{settings.dotnet.solution | default('') }}"
        }
      ]
    }
  }
}


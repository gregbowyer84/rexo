{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
  "schemaVersion": "1.0",
  "name": "dotnet-policy",
  "description": ".NET toolchain command contributions. Usable standalone or overlaid with embedded:standard.",
  "commands": {
    "restore": {
      "description": "Restore .NET dependencies.",
      "steps": [
        {
          "id": "dotnet-restore",
          "run": "dotnet restore{{vars.dotnet.solution | prefix(' ')}}"
        }
      ]
    },
    "build": {
      "description": "Build .NET projects.",
      "steps": [
        {
          "id": "dotnet-build",
          "run": "dotnet build{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} --no-restore"
        }
      ]
    },
    "test": {
      "description": "Run .NET tests.",
      "steps": [
        {
          "id": "dotnet-test",
          "run": "dotnet test{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} --logger trx {{outputs.tests.results | prefix('--results-directory ')}}",
          "outputs": {
            "testResults": [
              "{{outputs.tests.results}}/**/*.trx",
              "{{outputs.tests.results}}/**/*.xml"
            ],
            "coverage": [
              "{{outputs.tests.coverage}}/**/*.xml",
              "{{outputs.tests.coverage}}/**/*.cobertura.xml"
            ]
          }
        }
      ]
    },
    "analyze": {
      "description": "Run .NET code analysis.",
      "steps": [
        {
          "id": "dotnet-format-check",
          "run": "dotnet format{{vars.dotnet.solution | prefix(' ')}} --verify-no-changes {{outputs.analysis.reports | prefix('--report ')}}",
          "outputs": {
            "analysisReports": [
              "{{outputs.analysis.reports}}/**/*.json"
            ]
          }
        },
        {
          "id": "dotnet-build-warnings",
          "run": "dotnet build{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} -warnaserror --no-restore {{outputs.analysis.sarif | suffix('/dotnet-build.sarif') | prefix('/p:ErrorLog=')}}",
          "outputs": {
            "sarifReports": [
              "{{outputs.analysis.sarif}}/**/*.sarif"
            ]
          }
        }
      ]
    },
    "format": {
      "description": "Auto-format .NET source files.",
      "steps": [
        {
          "id": "dotnet-format",
          "run": "dotnet format{{vars.dotnet.solution | prefix(' ')}}"
        }
      ]
    }
  }
}


{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema/v1.0/schema.json",
  "schemaVersion": "1.0",
  "name": "dotnet-policy",
  "description": "Policy template for .NET repositories. Adds dotnet-specific commands.",
  "commands": {
    "restore": {
      "description": "Restore NuGet packages.",
      "options": {},
      "steps": [
        { "run": "dotnet restore", "description": "Restore packages" }
      ]
    },
    "format": {
      "description": "Check code formatting with dotnet format.",
      "options": {
        "fix": { "type": "bool", "default": "false" }
      },
      "steps": [
        {
          "run": "dotnet format --verify-no-changes",
          "description": "Verify formatting",
          "when": "{{options.fix}} != true"
        },
        {
          "run": "dotnet format",
          "description": "Apply formatting",
          "when": "{{options.fix}} == true"
        }
      ]
    },
    "pack": {
      "description": "Pack NuGet packages.",
      "options": {
        "configuration": { "type": "string", "default": "Release" }
      },
      "steps": [
        { "uses": "builtin:resolve-version", "description": "Resolve version" },
        { "uses": "builtin:build-artifacts",  "description": "Pack NuGet artifacts" }
      ]
    }
  },
  "aliases": {
    "r": "restore",
    "f": "format"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
  "schemaVersion": "1.0",
  "name": "dotnet-policy",
  "description": ".NET toolchain command contributions. Usable standalone or overlaid with embedded:standard.",
  "commands": {
    "restore": {
      "description": "Restore .NET dependencies.",
      "steps": [
        {
          "id": "dotnet-restore",
          "run": "dotnet restore{{vars.dotnet.solution | prefix(' ')}}{{vars.dotnet.restore.extraArgs | prefix(' ')}}"
        }
      ]
    },
    "build": {
      "description": "Build .NET projects.",
      "steps": [
        {
          "id": "dotnet-build",
          "run": "dotnet build{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} --no-restore{{vars.dotnet.build.extraArgs | prefix(' ')}}"
        }
      ]
    },
    "test": {
      "description": "Run .NET tests.",
      "steps": [
        {
          "id": "dotnet-test-no-coverage",
          "when": "{{vars.dotnet.test.coverage.mode == 'none'}}",
          "run": "dotnet test{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} --logger trx{{outputs.tests.results | prefix(' --results-directory ')}}{{vars.dotnet.test.runsettings | prefix(' --settings ')}}{{vars.dotnet.test.extraArgs | prefix(' ')}}",
          "outputs": {
            "testResults": [
              "{{outputs.tests.results}}/**/*.trx",
              "{{outputs.tests.results}}/**/*.xml"
            ]
          }
        },
        {
          "id": "dotnet-test",
          "when": "{{vars.dotnet.test.coverage.mode != 'none'}}",
          "run": "dotnet test{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} --logger trx{{outputs.tests.results | prefix(' --results-directory ')}}{{vars.dotnet.test.runsettings | prefix(' --settings ')}}{{vars.dotnet.test.extraArgs | prefix(' ')}} --collect:\"XPlat Code Coverage\" -- DataCollectionRunSettings.DataCollectors.DataCollector.Configuration.OutputDirectory={{outputs.tests.coverage}}",
          "outputs": {
            "testResults": [
              "{{outputs.tests.results}}/**/*.trx",
              "{{outputs.tests.results}}/**/*.xml"
            ],
            "coverage": [
              "{{outputs.tests.coverage}}/**/*.xml",
              "{{outputs.tests.coverage}}/**/*.cobertura.xml"
            ]
          }
        }
      ]
    },
    "analyze": {
      "description": "Run .NET code analysis.",
      "steps": [
        {
          "id": "dotnet-format-check",
          "run": "dotnet format{{vars.dotnet.solution | prefix(' ')}} --verify-no-changes{{outputs.analysis.reports | prefix(' --report ')}}{{vars.dotnet.analyze.formatExtraArgs | prefix(' ')}}",
          "outputs": {
            "analysisReports": [
              "{{outputs.analysis.reports}}/**/*.json"
            ]
          }
        },
        {
          "id": "dotnet-build-warnings",
          "run": "dotnet build{{vars.dotnet.solution | prefix(' ')}} -c {{vars.dotnet.configuration | default('Release')}} -warnaserror --no-restore{{outputs.analysis.sarif | suffix('/dotnet-build.sarif') | prefix(' /p:ErrorLog=')}}{{vars.dotnet.analyze.buildExtraArgs | prefix(' ')}}",
          "outputs": {
            "sarifReports": [
              "{{outputs.analysis.sarif}}/**/*.sarif"
            ]
          }
        }
      ]
    },
    "format": {
      "description": "Auto-format .NET source files.",
      "steps": [
        {
          "id": "dotnet-format",
          "run": "dotnet format{{vars.dotnet.solution | prefix(' ')}}{{vars.dotnet.format.extraArgs | prefix(' ')}}"
        }
      ]
    }
  }
}


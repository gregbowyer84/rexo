{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
  "schemaVersion": "1.0",
  "name": "dotnet-api-policy",
  "description": "Policy template for .NET web API and service projects. Provides the full dotnet lifecycle with Docker container lifecycle commands.",
  "commands": {
    "ci": {
      "description": "Run the full CI pipeline: validate, test, analyze, and build configured container artifacts.",
      "options": {},
      "steps": [
        {
          "uses": "builtin:validate",
          "description": "Validate repo.json"
        },
        {
          "uses": "builtin:resolve-version",
          "description": "Resolve version"
        },
        {
          "uses": "builtin:test",
          "description": "Run tests"
        },
        {
          "uses": "builtin:analyze",
          "description": "Run analysis"
        },
        {
          "uses": "builtin:build-artifacts",
          "description": "Build container artifacts"
        }
      ]
    },
    "release": {
      "description": "Run CI then tag and optionally push configured container artifacts.",
      "options": {
        "push": {
          "type": "bool",
          "default": false
        }
      },
      "steps": [
        {
          "uses": "builtin:validate",
          "description": "Validate repo.json"
        },
        {
          "uses": "builtin:resolve-version",
          "description": "Resolve version"
        },
        {
          "uses": "builtin:test",
          "description": "Run tests"
        },
        {
          "uses": "builtin:analyze",
          "description": "Run analysis"
        },
        {
          "uses": "builtin:build-artifacts",
          "description": "Build container artifacts"
        },
        {
          "uses": "builtin:tag-artifacts",
          "description": "Tag container artifacts"
        },
        {
          "uses": "builtin:push-artifacts",
          "description": "Push container images",
          "when": "{{options.push}} == true",
          "with": {
            "confirm": "{{options.push}}"
          }
        }
      ]
    },
    "restore": {
      "description": "Restore NuGet packages.",
      "options": {},
      "steps": [
        { "run": "dotnet restore", "description": "Restore packages" }
      ]
    },
    "format": {
      "description": "Check code formatting with dotnet format.",
      "options": {
        "fix": {
          "type": "bool",
          "default": false
        }
      },
      "steps": [
        {
          "run": "dotnet format --verify-no-changes",
          "description": "Verify formatting",
          "when": "{{options.fix}} != true"
        },
        {
          "run": "dotnet format",
          "description": "Apply formatting",
          "when": "{{options.fix}} == true"
        }
      ]
    },
    "stage": {
      "description": "Build and stage a Docker image for the named build stage.",
      "args": {
        "stage": { "required": true }
      },
      "options": {},
      "steps": [
        { "uses": "builtin:resolve-version", "description": "Resolve version" },
        { "uses": "builtin:docker-stage", "description": "Build Docker stage" }
      ]
    }
  },
  "aliases": {
    "r": "restore",
    "f": "format",
    "s": "stage"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema/v1.0/policy.schema.json",
  "schemaVersion": "1.0",
  "name": "node-policy",
  "description": "Node.js toolchain command contributions. Usable standalone or overlaid with embedded:standard.",
  "commands": {
    "restore": {
      "description": "Install Node.js dependencies.",
      "steps": [
        {
          "id": "node-install",
          "run": "{{vars.node.packageManager | default('npm')}} ci"
        }
      ]
    },
    "build": {
      "description": "Build Node.js project.",
      "steps": [
        {
          "id": "node-build",
          "run": "{{vars.node.packageManager | default('npm')}} run build --if-present"
        }
      ]
    },
    "test": {
      "description": "Run Node.js tests.",
      "steps": [
        {
          "id": "node-test",
          "run": "{{vars.node.packageManager | default('npm')}} test --if-present",
          "outputs": {
            "testResults": [
              "{{outputs.tests.results}}/**/*.xml",
              "{{outputs.tests.results}}/**/*.json"
            ],
            "coverage": [
              "{{outputs.tests.coverage}}/**/*"
            ]
          }
        }
      ]
    },
    "analyze": {
      "description": "Lint Node.js source files.",
      "steps": [
        {
          "id": "node-lint",
          "run": "{{vars.node.packageManager | default('npm')}} run lint --if-present",
          "outputs": {
            "analysisReports": [
              "{{outputs.analysis.reports}}/**/*"
            ]
          }
        },
        {
          "id": "node-lint-sarif",
          "run": "{{vars.node.packageManager | default('npm')}} run lint:sarif --if-present",
          "outputs": {
            "sarifReports": [
              "{{outputs.analysis.sarif}}/**/*.sarif"
            ]
          }
        }
      ]
    },
    "security": {
      "description": "Audit Node.js dependencies for known vulnerabilities.",
      "steps": [
        {
          "id": "node-audit",
          "run": "{{vars.node.packageManager | default('npm')}} audit --json --audit-level=high{{outputs.security.audit | prefix(' > ')}}",
          "outputs": {
            "securityReports": [
              "{{outputs.security.audit}}"
            ]
          }
        }
      ]
    }
  }
}



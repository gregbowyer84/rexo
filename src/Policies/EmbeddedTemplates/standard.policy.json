{
  "$schema": "https://raw.githubusercontent.com/agile-north/rexo/schema-v1.0/policy.schema.json",
  "schemaVersion": "1.0",
  "name": "standard-policy",
  "description": "Standard artifact lifecycle policy with user-facing commands.",
  "commands": {
    "plan": {
      "description": "Validate and show what would be built/pushed.",
      "options": {
        "push": {
          "type": "bool",
          "default": false
        }
      },
      "steps": [
        {
          "id": "validate",
          "uses": "builtin:validate"
        },
        {
          "id": "version",
          "uses": "builtin:resolve-version"
        },
        {
          "id": "plan",
          "uses": "builtin:plan-artifacts",
          "with": {
            "push": "{{options.push}}"
          }
        }
      ]
    },
    "validate": {
      "description": "Validate repository configuration.",
      "options": {},
      "steps": [
        {
          "id": "validate",
          "uses": "builtin:validate"
        }
      ]
    },
    "version": {
      "description": "Resolve repository version.",
      "options": {},
      "steps": [
        {
          "id": "version",
          "uses": "builtin:resolve-version"
        }
      ]
    },
    "test": {
      "description": "Run configured tests.",
      "options": {},
      "steps": [
        {
          "id": "test-content",
          "command": "test",
          "whenExists": true
        }
      ]
    },
    "analyze": {
      "description": "Run configured analysis.",
      "options": {},
      "steps": [
        {
          "id": "analyze-content",
          "command": "analyze",
          "whenExists": true
        }
      ]
    },
    "verify": {
      "description": "Validate, test, and analyze the repository.",
      "options": {},
      "steps": [
        {
          "id": "validate",
          "uses": "builtin:validate"
        },
        {
          "id": "verify-contributions",
          "command": "verify",
          "whenExists": true
        },
        {
          "id": "test",
          "command": "test",
          "whenExists": true
        },
        {
          "id": "analyze",
          "command": "analyze",
          "whenExists": true
        },
        {
          "id": "security",
          "command": "security",
          "whenExists": true
        }
      ]
    },
    "build": {
      "description": "Build and tag configured artifacts locally.",
      "options": {},
      "steps": [
        {
          "id": "validate",
          "uses": "builtin:validate"
        },
        {
          "id": "version",
          "uses": "builtin:resolve-version"
        },
        {
          "id": "build-artifacts",
          "uses": "builtin:build-artifacts"
        },
        {
          "id": "tag-artifacts",
          "uses": "builtin:tag-artifacts"
        }
      ]
    },
    "tag": {
      "description": "Tag configured artifacts.",
      "options": {},
      "steps": [
        {
          "id": "version",
          "uses": "builtin:resolve-version"
        },
        {
          "id": "tag",
          "uses": "builtin:tag-artifacts"
        }
      ]
    },
    "push": {
      "description": "Push configured artifacts when explicitly confirmed.",
      "options": {
        "confirm": {
          "type": "bool",
          "default": false
        }
      },
      "steps": [
        {
          "id": "push",
          "uses": "builtin:push-artifacts",
          "with": {
            "confirm": "{{options.confirm}}"
          }
        }
      ]
    },
    "release": {
      "description": "Verify, build, and optionally push configured artifacts.",
      "options": {
        "push": {
          "type": "bool",
          "default": false
        }
      },
      "steps": [
        {
          "id": "verify",
          "command": "verify",
          "whenExists": true
        },
        {
          "id": "build",
          "command": "build"
        },
        {
          "id": "push-artifacts",
          "uses": "builtin:push-artifacts",
          "when": "{{options.push}}",
          "with": {
            "confirm": "{{options.push}}"
          }
        }
      ]
    },
    "clean": {
      "description": "Remove generated Rexo output.",
      "options": {},
      "steps": [
        {
          "id": "clean",
          "uses": "builtin:clean"
        }
      ]
    }
  },
  "aliases": {
    "all": "release",
    "ship": "push"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/agile-north/rexo/schema/v1.0/schema.json",
  "title": "Rexo repository configuration schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "name",
    "commands",
    "aliases"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "https://raw.githubusercontent.com/agile-north/rexo/schema/v1.0/schema.json",
        "schema.json",
        "./schema.json",
        "../schema.json"
      ]
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "extends": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/repoCommand"
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "versioning": {
      "$ref": "#/$defs/versioning"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "tests": {
      "$ref": "#/$defs/tests"
    },
    "analysis": {
      "$ref": "#/$defs/analysis"
    },
    "pushRulesJson": {
      "type": "string"
    }
  },
  "$defs": {
    "repoCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steps"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/argConfig"
          }
        },
        "options": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/optionConfig"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          }
        }
      }
    },
    "argConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "optionConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "default": {
          "type": "string"
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "uses": {
          "type": "string"
        },
        "run": {
          "type": "string"
        },
        "when": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "continueOnError": {
          "type": "boolean"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "anyOf": [
        { "required": ["run"] },
        { "required": ["uses"] },
        { "required": ["command"] }
      ]
    },
    "versioning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "fallback": {
          "type": "string"
        },
        "settings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/settingValue"
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "settings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/settingValue"
          }
        }
      }
    },
    "settingValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "configuration": {
          "type": "string"
        },
        "resultsOutput": {
          "type": "string"
        },
        "coverageOutput": {
          "type": "string"
        },
        "collectCoverage": {
          "type": "boolean"
        },
        "coverageThreshold": {
          "type": "integer"
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "failOnIssues": {
          "type": "boolean"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "configuration": {
          "type": "string"
        }
      }
    }
  }
}
